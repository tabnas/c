# Syntax highlighting for .jsonic files
*.jsonic linguist-language=CUE

# The embedded grammar and line-sensitive sources must keep LF endings.
*.jsonic text eol=lf
*.ts text eol=lf

# csmith regression corpus and gzipped fixtures are data, not language.
ts/test/csmith-corpus/** linguist-vendored
ts/test/csmith-fixtures/*.gz binary
